<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Scaling Group to keep everything in the Safe Zone (center 72dp) -->
    <group
        android:translateX="54"
        android:translateY="54"
        android:scaleX="0.85"
        android:scaleY="0.85">
        <group
            android:translateX="-54"
            android:translateY="-54">

            <!-- 1. PHARMACY BUILDING (Bottom) -->
            <!-- Building Base (Dark Blue) -->
            <path
                android:fillColor="#003B73"
                android:pathData="M38,68 H70 V85 H38 Z" />

            <!-- Window with Medical Cross -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M56,72 H66 V80 H56 Z" />
            <path
                android:fillColor="#2E7D32"
                android:pathData="M59,76 H63 M61,74 V78"
                android:strokeWidth="1"
                android:strokeColor="#2E7D32"/>

            <!-- Door -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M42,75 H48 V85 H42 Z" />

            <!-- Striped Awning (Green & White) -->
            <path android:fillColor="#1B5E20" android:pathData="M35,60 H42 V68 H35 Z" />
            <path android:fillColor="#E8F5E9" android:pathData="M42,60 H49 V68 H42 Z" />
            <path android:fillColor="#1B5E20" android:pathData="M49,60 H56 V68 H49 Z" />
            <path android:fillColor="#E8F5E9" android:pathData="M56,60 H63 V68 H56 Z" />
            <path android:fillColor="#1B5E20" android:pathData="M63,60 H70 V68 H63 Z" />
            <path android:fillColor="#E8F5E9" android:pathData="M70,60 H73 V68 H70 Z" />

            <!-- 2. LOCATION PIN (Top) -->
            <path
                android:pathData="M54,10 C41,10 30,21 30,35 C30,53 54,76 54,76 C54,76 78,53 78,35 C78,21 67,10 54,10 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:startX="54" android:startY="10"
                        android:endX="54" android:endY="76"
                        android:type="linear">
                        <item android:offset="0" android:color="#2E7D32"/>
                        <item android:offset="1" android:color="#66BB6A"/>
                    </gradient>
                </aapt:attr>
            </path>

            <!-- White Center Circle -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M54,18 A17,17 0 1,0 54,52 A17,17 0 1,0 54,18 Z" />

            <!-- Detailed Symbols inside Circle -->
            <!-- Capsule (Blue & Green) -->
            <path android:fillColor="#1E88E5" android:pathData="M40,28 L46,34 L43,37 L37,31 Z" />
            <path android:fillColor="#43A047" android:pathData="M46,34 L52,40 L49,43 L43,37 Z" />

            <!-- Medicine Bottle -->
            <path android:fillColor="#F5F5F5" android:pathData="M56,28 H64 V44 H56 Z" /> <!-- Body -->
            <path android:fillColor="#1B5E20" android:pathData="M56,26 H64 V29 H56 Z" /> <!-- Cap -->

            <!-- Tablet (Circle) -->
            <path android:fillColor="#FFFFFF" android:pathData="M46,45 A4,4 0 1,0 54,45 A4,4 0 1,0 46,45 Z" android:strokeColor="#E0E0E0" android:strokeWidth="0.5"/>

            <!-- Leaf -->
            <path android:fillColor="#81C784" android:pathData="M64,40 C68,40 72,32 72,32 C72,32 66,28 64,34 Z" />

            <!-- 3. BRANDING TEXT (Bottom) -->
            <!-- JanAushadhi (Dark Blue) -->
            <path android:fillColor="#003B73" android:pathData="M25,92 H83 V96 H25 Z" />
            <!-- FINDER (Green) -->
            <path android:fillColor="#2E7D32" android:pathData="M40,98 H68 V100 H40 Z" />

        </group>
    </group>
</vector>